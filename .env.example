# 使用モデル
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-5

# 出力先ディレクトリ
OUTPUT_DIR=reports
METRICS_CSV_PATH=metrics_history.csv
