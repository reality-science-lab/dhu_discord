# Discord Bot
DISCORD_TOKEN=

# Anthropic API
ANTHROPIC_API_KEY=

# 対象サーバー(Guild) ID
GUILD_ID=1504714750557294682

# 集計から除外したいチャンネルID（カンマ区切り、運営専用チャンネルなど）
EXCLUDE_CHANNEL_IDS=

# 自己紹介チャンネルID
